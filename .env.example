# Signs your login session. Use a long random string.
JWT_SECRET=
# Encrypts stored Google tokens at rest. Long random string.
# Falls back to JWT_SECRET if left blank.
ENCRYPTION_KEY=
# Your Google OAuth client (Gmail read-only scope).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback
# Set true when serving over HTTPS.
COOKIE_SECURE=false
# Where the SQLite database file lives.
DB_PATH=../dreamcatcher.db
